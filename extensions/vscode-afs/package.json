{
  "name": "afs-vscode",
  "displayName": "AFS - Agentic File System",
  "description": "Context management and workspace-aware chat for AFS",
  "version": "0.2.0",
  "publisher": "scawful",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scawful/afs"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/.context/metadata.json",
    "onChatParticipant:afs.chat",
    "onView:afs.dashboard",
    "onView:afs.contextExplorer",
    "onView:afs.commands",
    "onCommand:afs.context.init",
    "onCommand:afs.context.discover",
    "onCommand:afs.context.mount",
    "onCommand:afs.context.unmount",
    "onCommand:afs.index.rebuild",
    "onCommand:afs.index.query",
    "onCommand:afs.index.queryQuickOpen",
    "onCommand:afs.mcp.register",
    "onCommand:afs.mcp.unregister",
    "onCommand:afs.mcp.status",
    "onCommand:afs.server.restart",
    "onCommand:afs.server.showLogs",
    "onCommand:afs.treeView.refresh",
    "onCommand:afs.dashboard.refresh",
    "onCommand:afs.commands.refresh",
    "onCommand:afs.chat.open"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "afs-explorer",
          "title": "AFS",
          "icon": "media/icons/afs-logo.svg"
        }
      ]
    },
    "views": {
      "afs-explorer": [
        {
          "id": "afs.dashboard",
          "name": "Dashboard",
          "type": "webview"
        },
        {
          "id": "afs.contextExplorer",
          "name": "Contexts",
          "contextualTitle": "AFS Context Explorer"
        },
        {
          "id": "afs.commands",
          "name": "Commands"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "afs.chat",
        "name": "afs",
        "fullName": "AFS",
        "description": "Ask about workspace context, scratchpad state, and AFS health",
        "isSticky": true,
        "commands": [
          {
            "name": "status",
            "description": "Summarize context health and freshness"
          },
          {
            "name": "query",
            "description": "Search indexed AFS context before answering"
          },
          {
            "name": "scratchpad",
            "description": "Review scratchpad state and deferred notes"
          },
          {
            "name": "pack",
            "description": "Use the current AFS session pack for context"
          }
        ],
        "disambiguation": [
          {
            "category": "afs_context",
            "description": "The user wants help grounded in AFS workspace context, scratchpad notes, freshness, mounts, or indexed context search.",
            "examples": [
              "What does my AFS scratchpad say about this repo?",
              "Summarize the current context health for this workspace",
              "Search the AFS context for session bootstrap changes"
            ]
          }
        ]
      }
    ],
    "viewsWelcome": [
      {
        "view": "afs.contextExplorer",
        "contents": "No AFS contexts found.\n[Initialize Context](command:afs.context.init)\n[Discover Contexts](command:afs.context.discover)",
        "when": "!afs.active"
      }
    ],
    "commands": [
      { "command": "afs.context.init", "title": "AFS: Initialize Context", "category": "AFS" },
      { "command": "afs.context.discover", "title": "AFS: Discover Contexts", "category": "AFS" },
      { "command": "afs.context.mount", "title": "AFS: Mount Source", "category": "AFS" },
      { "command": "afs.context.unmount", "title": "AFS: Unmount Source", "category": "AFS" },
      { "command": "afs.index.rebuild", "title": "AFS: Rebuild Context Index", "category": "AFS" },
      { "command": "afs.index.query", "title": "AFS: Query Context Index", "category": "AFS" },
      { "command": "afs.index.queryQuickOpen", "title": "AFS: Quick Open Context File", "category": "AFS" },
      { "command": "afs.mcp.register", "title": "AFS: Register MCP Server", "category": "AFS" },
      { "command": "afs.mcp.unregister", "title": "AFS: Unregister MCP Server", "category": "AFS" },
      { "command": "afs.mcp.status", "title": "AFS: MCP Status", "category": "AFS" },
      { "command": "afs.server.restart", "title": "AFS: Restart Server", "category": "AFS" },
      { "command": "afs.server.showLogs", "title": "AFS: Show Server Logs", "category": "AFS" },
      { "command": "afs.treeView.refresh", "title": "AFS: Refresh Context Explorer", "icon": "$(refresh)", "category": "AFS" },
      { "command": "afs.dashboard.refresh", "title": "AFS: Refresh Dashboard", "icon": "$(refresh)", "category": "AFS" },
      { "command": "afs.commands.refresh", "title": "AFS: Refresh Commands", "icon": "$(refresh)", "category": "AFS" },
      { "command": "afs.chat.open", "title": "AFS: Open Chat", "category": "AFS" }
    ],
    "submenus": [
      {
        "id": "afs.menu",
        "label": "AFS"
      }
    ],
    "menus": {
      "menubar/view": [
        {
          "submenu": "afs.menu",
          "group": "9_afs"
        }
      ],
      "afs.menu": [
        { "command": "afs.context.discover", "group": "1_context" },
        { "command": "afs.context.init", "group": "1_context" },
        { "command": "afs.context.mount", "group": "1_context" },
        { "command": "afs.index.rebuild", "group": "2_index" },
        { "command": "afs.index.query", "group": "2_index" },
        { "command": "afs.index.queryQuickOpen", "group": "2_index" },
        { "command": "afs.chat.open", "group": "3_chat" },
        { "command": "afs.mcp.register", "group": "4_server" },
        { "command": "afs.mcp.status", "group": "4_server" },
        { "command": "afs.server.restart", "group": "4_server" },
        { "command": "afs.server.showLogs", "group": "4_server" }
      ],
      "view/title": [
        { "command": "afs.treeView.refresh", "when": "view == afs.contextExplorer", "group": "navigation" },
        { "command": "afs.dashboard.refresh", "when": "view == afs.dashboard", "group": "navigation" },
        { "command": "afs.commands.refresh", "when": "view == afs.commands", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "afs.context.mount", "when": "view == afs.contextExplorer && viewItem == contextRoot" },
        { "command": "afs.context.unmount", "when": "view == afs.contextExplorer && viewItem == mountPoint" },
        { "command": "afs.index.rebuild", "when": "view == afs.contextExplorer && viewItem == contextRoot" }
      ],
      "explorer/context": [
        { "command": "afs.context.init", "when": "explorerResourceIsFolder", "group": "afs@1" }
      ]
    },
    "configuration": {
      "title": "AFS - Agentic File System",
      "properties": {
        "afs.server.mode": {
          "type": "string",
          "enum": ["mcp", "cli", "auto"],
          "default": "auto",
          "description": "Transport mode: 'mcp' spawns MCP stdio server, 'cli' uses CLI commands, 'auto' tries MCP first."
        },
        "afs.server.command": {
          "type": "string",
          "default": "",
          "description": "Path to the AFS CLI binary. If empty, auto-detection is used."
        },
        "afs.server.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python interpreter for AFS. If empty, uses workspace .venv or system python3."
        },
        "afs.server.args": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional arguments for the MCP server."
        },
        "afs.server.env": {
          "type": "object",
          "default": {},
          "description": "Additional environment variables for the AFS server process."
        },
        "afs.server.timeout": {
          "type": "number",
          "default": 30000,
          "description": "Timeout in milliseconds for MCP requests."
        },
        "afs.discovery.searchPaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional paths for context discovery."
        },
        "afs.discovery.maxDepth": {
          "type": "number",
          "default": 3,
          "description": "Maximum directory depth for context discovery."
        },
        "afs.discovery.autoDiscover": {
          "type": "boolean",
          "default": true,
          "description": "Auto-discover contexts on activation."
        },
        "afs.index.autoRebuild": {
          "type": "boolean",
          "default": false,
          "description": "Auto-rebuild index when .context files change."
        },
        "afs.mcp.autoRegister": {
          "type": "boolean",
          "default": false,
          "description": "Auto-register AFS in editor MCP config on activation."
        },
        "afs.mcp.configPath": {
          "type": "string",
          "default": "",
          "description": "Override path for editor MCP config file."
        },
        "afs.mcp.contextRoot": {
          "type": "string",
          "default": "",
          "description": "Optional editor-specific context root used when resolving MCP config candidates."
        },
        "afs.treeView.showEmptyMounts": {
          "type": "boolean",
          "default": false,
          "description": "Show mount types with no entries."
        },
        "afs.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show AFS status in the status bar."
        },
        "afs.logging.level": {
          "type": "string",
          "enum": ["off", "error", "warn", "info", "debug", "trace"],
          "default": "info",
          "description": "Log level for the AFS output channel."
        },
        "afs.chat.modelProfile": {
          "type": "string",
          "enum": ["auto", "generic", "gemini", "claude", "codex"],
          "default": "auto",
          "description": "AFS model profile for session packs. Auto infers from the selected chat model when possible."
        },
        "afs.chat.workflow": {
          "type": "string",
          "enum": ["general", "scan_fast", "edit_fast", "review_deep", "root_cause_deep"],
          "default": "general",
          "description": "Default AFS workflow hint for chat context injection."
        },
        "afs.chat.toolProfile": {
          "type": "string",
          "enum": ["default", "context_readonly", "context_repair", "edit_and_verify", "handoff_only"],
          "default": "context_readonly",
          "description": "Default AFS tool profile hint for chat context injection."
        },
        "afs.chat.packMode": {
          "type": "string",
          "enum": ["focused", "retrieval", "full_slice"],
          "default": "focused",
          "description": "Default session pack mode for AFS chat requests."
        },
        "afs.chat.maxQueryResults": {
          "type": "number",
          "default": 6,
          "description": "Maximum number of indexed AFS query hits to include in chat context."
        },
        "afs.chat.includeContent": {
          "type": "boolean",
          "default": false,
          "description": "Include indexed file content snippets in chat context when available."
        },
        "afs.chat.includeSessionPrompt": {
          "type": "boolean",
          "default": true,
          "description": "Include the prepared AFS session prompt in chat context when available."
        },
        "afs.chat.mountTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["memory", "knowledge", "tools", "scratchpad", "history", "hivemind", "global", "items", "monorepo"]
          },
          "default": [],
          "description": "Optional mount filter for indexed context queries in chat. Empty means all mounts."
        },
        "afs.antigravity.contextRoot": {
          "type": "string",
          "default": "",
          "markdownDeprecationMessage": "Use `afs.mcp.contextRoot` instead.",
          "description": "Deprecated compatibility setting for editor-specific MCP config discovery."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "test": "node esbuild.test.mjs && node --test dist-test/suite/**/*.test.js",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.0",
    "glob": "^10.3.0",
    "eslint": "^8.50.0",
    "mocha": "^10.2.0",
    "typescript": "^5.3.0"
  }
}
