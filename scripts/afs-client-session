#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 3 ]; then
  echo "usage: afs-client-session <client-label> <default-command> <env-var> [--bootstrap-only] [--context-query <text>] [--session-task <text>] [--skills-prompt <text>] [--session-model <model>] [--workflow <name>] [--tool-profile <name>] [--pack-mode <name>] [--session-pack|--no-session-pack] [--skills-match|--no-skills-match] [--monitor-agents|--no-monitor-agents] [--seed-jobs|--no-seed-jobs] [--seed-profile <name>] [--seed-cadence <name>] [--wait-for-agents|--no-wait-for-agents] [--prompt <text>] [--prompt-file <path>] [--turn-id <id>] [--] [client-args...]" >&2
  exit 2
fi

CLIENT_LABEL="$1"
DEFAULT_COMMAND="$2"
COMMAND_ENV_VAR="$3"
shift 3

BOOTSTRAP_ONLY=0
WAIT_OVERRIDE=""
MONITOR_OVERRIDE=""
SESSION_QUERY_OVERRIDE=""
SESSION_TASK_OVERRIDE=""
SKILLS_PROMPT_OVERRIDE=""
SESSION_MODEL_OVERRIDE=""
WORKFLOW_OVERRIDE=""
TOOL_PROFILE_OVERRIDE=""
PACK_MODE_OVERRIDE=""
SESSION_PACK_OVERRIDE=""
SKILLS_MATCH_OVERRIDE=""
SEED_JOBS_OVERRIDE=""
SEED_PROFILE_OVERRIDE=""
SEED_CADENCE_OVERRIDE=""
PROMPT_OVERRIDE=""
PROMPT_FILE_OVERRIDE=""
TURN_ID_OVERRIDE=""
while [ "$#" -gt 0 ]; do
  case "${1:-}" in
    --bootstrap-only)
      BOOTSTRAP_ONLY=1
      shift
      ;;
    --context-query)
      SESSION_QUERY_OVERRIDE="${2:-}"
      shift 2
      ;;
    --session-task)
      SESSION_TASK_OVERRIDE="${2:-}"
      shift 2
      ;;
    --skills-prompt)
      SKILLS_PROMPT_OVERRIDE="${2:-}"
      shift 2
      ;;
    --session-model)
      SESSION_MODEL_OVERRIDE="${2:-}"
      shift 2
      ;;
    --workflow)
      WORKFLOW_OVERRIDE="${2:-}"
      shift 2
      ;;
    --tool-profile)
      TOOL_PROFILE_OVERRIDE="${2:-}"
      shift 2
      ;;
    --pack-mode)
      PACK_MODE_OVERRIDE="${2:-}"
      shift 2
      ;;
    --session-pack)
      SESSION_PACK_OVERRIDE=1
      shift
      ;;
    --no-session-pack)
      SESSION_PACK_OVERRIDE=0
      shift
      ;;
    --skills-match)
      SKILLS_MATCH_OVERRIDE=1
      shift
      ;;
    --no-skills-match)
      SKILLS_MATCH_OVERRIDE=0
      shift
      ;;
    --seed-jobs)
      SEED_JOBS_OVERRIDE=1
      shift
      ;;
    --no-seed-jobs)
      SEED_JOBS_OVERRIDE=0
      shift
      ;;
    --seed-profile)
      SEED_PROFILE_OVERRIDE="${2:-}"
      shift 2
      ;;
    --seed-cadence)
      SEED_CADENCE_OVERRIDE="${2:-}"
      shift 2
      ;;
    --monitor-agents)
      MONITOR_OVERRIDE=1
      shift
      ;;
    --no-monitor-agents)
      MONITOR_OVERRIDE=0
      shift
      ;;
    --wait-for-agents)
      WAIT_OVERRIDE=1
      shift
      ;;
    --no-wait-for-agents)
      WAIT_OVERRIDE=0
      shift
      ;;
    --prompt)
      PROMPT_OVERRIDE="${2:-}"
      shift 2
      ;;
    --prompt-file)
      PROMPT_FILE_OVERRIDE="${2:-}"
      shift 2
      ;;
    --turn-id)
      TURN_ID_OVERRIDE="${2:-}"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AFS_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
AFS_CLI="${AFS_ROOT}/scripts/afs"

export AFS_ROOT
export AFS_CLI
export AFS_SESSION_EVENT_BIN="${AFS_SESSION_EVENT_BIN:-${AFS_ROOT}/scripts/afs-session-notify}"
export AFS_SESSION_CLIENT="${CLIENT_LABEL}"
if [ -z "${AFS_SESSION_ID:-}" ]; then
  export AFS_SESSION_ID="$(
    python3 - <<'PY'
import uuid
print(uuid.uuid4().hex[:12])
PY
  )"
fi

find_repo_config() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/afs.toml" ]; then
      printf '%s\n' "$dir/afs.toml"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

if [ -z "${AFS_CONFIG_PATH:-}" ]; then
  if repo_config="$(find_repo_config)"; then
    export AFS_CONFIG_PATH="$repo_config"
  fi
fi

export AFS_PREFER_REPO_CONFIG="${AFS_PREFER_REPO_CONFIG:-1}"
if [ "${AFS_PREFER_REPO_CONFIG}" = "1" ]; then
  export AFS_PREFER_USER_CONFIG=0
fi

CLIENT_ENV_PREFIX="$(printf '%s' "${CLIENT_LABEL}" | tr '[:lower:]-' '[:upper:]_')"
CLIENT_ROOTS_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_MCP_ALLOWED_ROOTS"
DEFAULT_CLIENT_ROOTS="${!CLIENT_ROOTS_ENV_VAR:-${AFS_CLIENT_MCP_ALLOWED_ROOTS:-}}"
if [ -n "${DEFAULT_CLIENT_ROOTS}" ] && [ -z "${AFS_MCP_ALLOWED_ROOTS:-}" ]; then
  export AFS_MCP_ALLOWED_ROOTS="${DEFAULT_CLIENT_ROOTS}"
fi

CLIENT_WAIT_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_WAIT_FOR_AGENTS"
WAIT_FOR_AGENTS="${WAIT_OVERRIDE:-${!CLIENT_WAIT_ENV_VAR:-${AFS_CLIENT_WAIT_FOR_AGENTS:-1}}}"
CLIENT_MONITOR_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_MONITOR_AGENTS"
MONITOR_AGENTS="${MONITOR_OVERRIDE:-${!CLIENT_MONITOR_ENV_VAR:-${AFS_CLIENT_MONITOR_AGENTS:-1}}}"
CLIENT_NATIVE_PROMPT_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_NATIVE_PROMPT"
NATIVE_PROMPT_ENABLED="${!CLIENT_NATIVE_PROMPT_ENV_VAR:-${AFS_CLIENT_NATIVE_PROMPT:-1}}"
CLIENT_WAIT_TIMEOUT_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_WAIT_TIMEOUT_SECONDS"
WAIT_TIMEOUT_SECONDS="${AFS_CLIENT_WAIT_TIMEOUT_SECONDS:-30}"
if [ -n "${!CLIENT_WAIT_TIMEOUT_ENV_VAR:-}" ]; then
  WAIT_TIMEOUT_SECONDS="${!CLIENT_WAIT_TIMEOUT_ENV_VAR}"
fi
CLIENT_VERIFICATION_MODE_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_VERIFICATION_MODE"
SESSION_VERIFICATION_MODE="${!CLIENT_VERIFICATION_MODE_ENV_VAR:-${AFS_CLIENT_SESSION_VERIFICATION_MODE:-warn}}"
CLIENT_RECORD_RUNS_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_RECORD_RUNS"
RECORD_AGENT_RUNS="${!CLIENT_RECORD_RUNS_ENV_VAR:-${AFS_CLIENT_RECORD_RUNS:-1}}"
CLIENT_SEED_JOBS_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SEED_JOBS"
SEED_AGENT_JOBS="${SEED_JOBS_OVERRIDE:-${!CLIENT_SEED_JOBS_ENV_VAR:-${AFS_CLIENT_SEED_JOBS:-1}}}"
CLIENT_SEED_PROFILE_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SEED_PROFILE"
SEED_AGENT_JOB_PROFILE="${SEED_PROFILE_OVERRIDE:-${!CLIENT_SEED_PROFILE_ENV_VAR:-${AFS_CLIENT_SEED_PROFILE:-repo-maintenance}}}"
CLIENT_SEED_CADENCE_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SEED_CADENCE"
SEED_AGENT_JOB_CADENCE="${SEED_CADENCE_OVERRIDE:-${!CLIENT_SEED_CADENCE_ENV_VAR:-${AFS_CLIENT_SEED_CADENCE:-daily}}}"

DEFAULT_SESSION_MODEL="generic"
case "${CLIENT_LABEL}" in
  gemini|claude|codex)
    DEFAULT_SESSION_MODEL="${CLIENT_LABEL}"
    ;;
esac
CLIENT_SESSION_QUERY_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_QUERY"
SESSION_QUERY="${SESSION_QUERY_OVERRIDE:-${!CLIENT_SESSION_QUERY_ENV_VAR:-${AFS_CLIENT_SESSION_QUERY:-}}}"
CLIENT_SESSION_TASK_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_TASK"
SESSION_TASK="${SESSION_TASK_OVERRIDE:-${!CLIENT_SESSION_TASK_ENV_VAR:-${AFS_CLIENT_SESSION_TASK:-}}}"
CLIENT_SESSION_MODEL_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_MODEL"
SESSION_MODEL="${SESSION_MODEL_OVERRIDE:-${!CLIENT_SESSION_MODEL_ENV_VAR:-${AFS_CLIENT_SESSION_MODEL:-${DEFAULT_SESSION_MODEL}}}}"
CLIENT_SESSION_WORKFLOW_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_WORKFLOW"
SESSION_WORKFLOW="${WORKFLOW_OVERRIDE:-${!CLIENT_SESSION_WORKFLOW_ENV_VAR:-${AFS_CLIENT_SESSION_WORKFLOW:-general}}}"
CLIENT_SESSION_TOOL_PROFILE_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_TOOL_PROFILE"
SESSION_TOOL_PROFILE="${TOOL_PROFILE_OVERRIDE:-${!CLIENT_SESSION_TOOL_PROFILE_ENV_VAR:-${AFS_CLIENT_SESSION_TOOL_PROFILE:-default}}}"
CLIENT_SESSION_PACK_MODE_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_PACK_MODE"
SESSION_PACK_MODE="${PACK_MODE_OVERRIDE:-${!CLIENT_SESSION_PACK_MODE_ENV_VAR:-${AFS_CLIENT_SESSION_PACK_MODE:-focused}}}"
CLIENT_SKILLS_PROMPT_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_SKILLS_PROMPT"
SKILLS_PROMPT="${SKILLS_PROMPT_OVERRIDE:-${!CLIENT_SKILLS_PROMPT_ENV_VAR:-${AFS_CLIENT_SESSION_SKILLS_PROMPT:-${SESSION_QUERY}}}}"
CLIENT_SESSION_PACK_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_PACK"
SESSION_PACK_ENABLED="${SESSION_PACK_OVERRIDE:-${!CLIENT_SESSION_PACK_ENV_VAR:-${AFS_CLIENT_SESSION_PACK:-1}}}"
CLIENT_SKILLS_MATCH_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SKILLS_MATCH"
SKILLS_MATCH_ENABLED="${SKILLS_MATCH_OVERRIDE:-${!CLIENT_SKILLS_MATCH_ENV_VAR:-${AFS_CLIENT_SKILLS_MATCH:-1}}}"
CLIENT_SESSION_PROMPT_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_PROMPT"
SESSION_PROMPT="${PROMPT_OVERRIDE:-${!CLIENT_SESSION_PROMPT_ENV_VAR:-${AFS_CLIENT_SESSION_PROMPT:-}}}"
CLIENT_SESSION_PROMPT_FILE_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_PROMPT_FILE"
SESSION_PROMPT_FILE="${PROMPT_FILE_OVERRIDE:-${!CLIENT_SESSION_PROMPT_FILE_ENV_VAR:-${AFS_CLIENT_SESSION_PROMPT_FILE:-}}}"
CLIENT_SESSION_TURN_ID_ENV_VAR="AFS_${CLIENT_ENV_PREFIX}_SESSION_TURN_ID"
SESSION_TURN_ID="${TURN_ID_OVERRIDE:-${!CLIENT_SESSION_TURN_ID_ENV_VAR:-${AFS_CLIENT_SESSION_TURN_ID:-}}}"
SESSION_PROMPT_TEXT=""

if [ -n "${SESSION_PROMPT_FILE}" ]; then
  if [ ! -r "${SESSION_PROMPT_FILE}" ]; then
    echo "prompt file not readable: ${SESSION_PROMPT_FILE}" >&2
    exit 1
  fi
  SESSION_PROMPT_TEXT="$(cat "${SESSION_PROMPT_FILE}")"
elif [ -n "${SESSION_PROMPT}" ]; then
  SESSION_PROMPT_TEXT="${SESSION_PROMPT}"
fi

if [ -z "${SESSION_QUERY}" ] && [ -n "${SESSION_PROMPT_TEXT}" ]; then
  SESSION_QUERY="${SESSION_PROMPT_TEXT}"
fi
if [ -z "${SESSION_TASK}" ] && [ -n "${SESSION_PROMPT_TEXT}" ]; then
  SESSION_TASK="${SESSION_PROMPT_TEXT}"
fi
if [ -z "${SKILLS_PROMPT}" ] && [ -n "${SESSION_PROMPT_TEXT}" ]; then
  SKILLS_PROMPT="${SESSION_PROMPT_TEXT}"
fi

generate_session_token() {
  local prefix="$1"
  python3 - "$prefix" <<'PY'
import sys
import uuid

print(f"{sys.argv[1]}-{uuid.uuid4().hex[:12]}")
PY
}

if [ -n "${SESSION_PROMPT}" ] || [ -n "${SESSION_PROMPT_FILE}" ] || [ -n "${SESSION_TURN_ID}" ]; then
  if [ -z "${SESSION_TURN_ID}" ]; then
    SESSION_TURN_ID="$(generate_session_token turn)"
  fi
  export AFS_SESSION_DEFAULT_TURN_ID="${SESSION_TURN_ID}"
else
  unset AFS_SESSION_DEFAULT_TURN_ID 2>/dev/null || true
fi

SESSION_PREPARE_ARGS=(
  session prepare-client
  --client "${CLIENT_LABEL}"
  --session-id "${AFS_SESSION_ID}"
  --cwd "${PWD}"
  --model "${SESSION_MODEL}"
  --workflow "${SESSION_WORKFLOW}"
  --tool-profile "${SESSION_TOOL_PROFILE}"
  --pack-mode "${SESSION_PACK_MODE}"
)
if [ -n "${SESSION_QUERY}" ]; then
  SESSION_PREPARE_ARGS+=(--query "${SESSION_QUERY}")
fi
if [ -n "${SESSION_TASK}" ]; then
  SESSION_PREPARE_ARGS+=(--task "${SESSION_TASK}")
fi
if [ -n "${SKILLS_PROMPT}" ]; then
  SESSION_PREPARE_ARGS+=(--skills-prompt "${SKILLS_PROMPT}")
fi
if [ "${SESSION_PACK_ENABLED}" = "0" ]; then
  SESSION_PREPARE_ARGS+=(--no-session-pack)
fi
if [ "${SKILLS_MATCH_ENABLED}" = "0" ]; then
  SESSION_PREPARE_ARGS+=(--no-skills-match)
fi
SESSION_PREPARE_ARGS+=(--json)

SESSION_PREPARE_JSON_PAYLOAD="$("${AFS_CLI}" "${SESSION_PREPARE_ARGS[@]}" 2>/dev/null || true)"
if [ -n "${SESSION_PREPARE_JSON_PAYLOAD}" ]; then
  readarray -t bootstrap_fields < <(
    python3 -c '
import json
import sys

payload = json.loads(sys.argv[1])
bootstrap = (payload.get("bootstrap") or {}).get("artifact_paths") or {}
pack = (payload.get("pack") or {}).get("artifact_paths") or {}
skills = (payload.get("skills") or {}).get("artifact_paths") or {}
prompt = (payload.get("prompt") or {}).get("artifact_paths") or {}
artifacts = payload.get("artifact_paths") or {}
print(bootstrap.get("json", ""))
print(bootstrap.get("markdown", ""))
print(payload.get("context_path", ""))
print(pack.get("json", ""))
print(pack.get("markdown", ""))
print(skills.get("json", ""))
print(prompt.get("json", ""))
print(prompt.get("text", ""))
print(artifacts.get("json", ""))
cli_hints = payload.get("cli_hints") or {}
print(cli_hints.get("query_shortcut", ""))
print(cli_hints.get("query_canonical", ""))
print(cli_hints.get("index_rebuild", ""))
print(cli_hints.get("agent_jobs_inbox", ""))
print(cli_hints.get("verify_plan", ""))
print(cli_hints.get("verify_run", ""))
structured = payload.get("structured_guidance") or {}
print(structured.get("recommended_schema", ""))
print(structured.get("followup_schema", ""))
repair_loop = structured.get("repair_loop") or []
print(" | ".join(str(item) for item in repair_loop if str(item).strip()))
' "${SESSION_PREPARE_JSON_PAYLOAD}"
  )
  export AFS_SESSION_BOOTSTRAP_JSON="${bootstrap_fields[0]:-}"
  export AFS_SESSION_BOOTSTRAP_MARKDOWN="${bootstrap_fields[1]:-}"
  export AFS_ACTIVE_CONTEXT_ROOT="${bootstrap_fields[2]:-}"
  export AFS_SESSION_PACK_JSON="${bootstrap_fields[3]:-}"
  export AFS_SESSION_PACK_MARKDOWN="${bootstrap_fields[4]:-}"
  export AFS_SESSION_SKILLS_JSON="${bootstrap_fields[5]:-}"
  export AFS_SESSION_SYSTEM_PROMPT_JSON="${bootstrap_fields[6]:-}"
  export AFS_SESSION_SYSTEM_PROMPT_TEXT="${bootstrap_fields[7]:-}"
  export AFS_SESSION_CLIENT_PAYLOAD_JSON="${bootstrap_fields[8]:-}"
  export AFS_SESSION_QUERY_HINT="${bootstrap_fields[9]:-}"
  export AFS_SESSION_CONTEXT_QUERY_HINT="${bootstrap_fields[10]:-}"
  export AFS_SESSION_INDEX_REBUILD_HINT="${bootstrap_fields[11]:-}"
  export AFS_SESSION_AGENT_JOBS_INBOX_HINT="${bootstrap_fields[12]:-}"
  export AFS_SESSION_VERIFY_PLAN_HINT="${bootstrap_fields[13]:-}"
  export AFS_SESSION_VERIFY_RUN_HINT="${bootstrap_fields[14]:-}"
  export AFS_SESSION_RECOMMENDED_SCHEMA="${bootstrap_fields[15]:-}"
  export AFS_SESSION_FOLLOWUP_SCHEMA="${bootstrap_fields[16]:-}"
  export AFS_SESSION_REPAIR_LOOP_HINT="${bootstrap_fields[17]:-}"
fi

if [ -n "${AFS_SESSION_BOOTSTRAP_MARKDOWN:-}" ]; then
  echo "AFS bootstrap (${CLIENT_LABEL}): ${AFS_SESSION_BOOTSTRAP_MARKDOWN}" >&2
fi
if [ -n "${AFS_SESSION_PACK_MARKDOWN:-}" ]; then
  echo "AFS pack (${CLIENT_LABEL}): ${AFS_SESSION_PACK_MARKDOWN}" >&2
fi
if [ -n "${AFS_SESSION_SKILLS_JSON:-}" ]; then
  echo "AFS skills (${CLIENT_LABEL}): ${AFS_SESSION_SKILLS_JSON}" >&2
fi
if [ -n "${AFS_SESSION_SYSTEM_PROMPT_TEXT:-}" ]; then
  echo "AFS system prompt (${CLIENT_LABEL}): ${AFS_SESSION_SYSTEM_PROMPT_TEXT}" >&2
fi
if [ -n "${AFS_SESSION_CLIENT_PAYLOAD_JSON:-}" ]; then
  echo "AFS session payload (${CLIENT_LABEL}): ${AFS_SESSION_CLIENT_PAYLOAD_JSON}" >&2
fi
if [ -n "${AFS_SESSION_AGENT_JOBS_INBOX_HINT:-}" ]; then
  echo "AFS agent jobs inbox (${CLIENT_LABEL}): ${AFS_SESSION_AGENT_JOBS_INBOX_HINT}" >&2
fi
if [ -n "${AFS_SESSION_QUERY_HINT:-}" ]; then
  echo "AFS query hint (${CLIENT_LABEL}): ${AFS_SESSION_QUERY_HINT}" >&2
fi
if [ -n "${AFS_SESSION_CONTEXT_QUERY_HINT:-}" ]; then
  echo "AFS canonical query hint (${CLIENT_LABEL}): ${AFS_SESSION_CONTEXT_QUERY_HINT}" >&2
fi
if [ -n "${AFS_SESSION_INDEX_REBUILD_HINT:-}" ]; then
  echo "AFS index hint (${CLIENT_LABEL}): ${AFS_SESSION_INDEX_REBUILD_HINT}" >&2
fi
if [ -n "${AFS_SESSION_VERIFY_PLAN_HINT:-}" ]; then
  echo "AFS verify plan hint (${CLIENT_LABEL}): ${AFS_SESSION_VERIFY_PLAN_HINT}" >&2
fi
if [ -n "${AFS_SESSION_VERIFY_RUN_HINT:-}" ]; then
  echo "AFS verify run hint (${CLIENT_LABEL}): ${AFS_SESSION_VERIFY_RUN_HINT}" >&2
fi
if [ -n "${AFS_SESSION_RECOMMENDED_SCHEMA:-}" ]; then
  echo "AFS structured schema (${CLIENT_LABEL}): ${AFS_SESSION_RECOMMENDED_SCHEMA}" >&2
fi
if [ -n "${AFS_SESSION_REPAIR_LOOP_HINT:-}" ]; then
  echo "AFS repair loop (${CLIENT_LABEL}): ${AFS_SESSION_REPAIR_LOOP_HINT}" >&2
fi
if [ -n "${AFS_SESSION_ID:-}" ]; then
  echo "AFS session (${CLIENT_LABEL}): ${AFS_SESSION_ID}" >&2
fi
if [ -n "${AFS_CONFIG_PATH:-}" ]; then
  echo "AFS config (${CLIENT_LABEL}): ${AFS_CONFIG_PATH}" >&2
fi

if [ "${BOOTSTRAP_ONLY}" = "1" ]; then
  exit 0
fi

CLIENT_COMMAND="${!COMMAND_ENV_VAR:-${DEFAULT_COMMAND}}"
if ! command -v "${CLIENT_COMMAND}" >/dev/null 2>&1; then
  echo "client command not found: ${CLIENT_COMMAND}" >&2
  echo "set ${COMMAND_ENV_VAR} to override the executable path" >&2
  exit 127
fi

CLIENT_ARGS=("$@")
CLIENT_EXTRA_ARGS=()

client_args_has_flag() {
  local flag="$1"
  local arg
  for arg in "${CLIENT_ARGS[@]}"; do
    case "${arg}" in
      "${flag}"|"${flag}"=*) return 0 ;;
    esac
  done
  return 1
}

client_args_has_config_key() {
  local key="$1"
  local index=0
  local arg=""
  local value=""
  while [ "${index}" -lt "${#CLIENT_ARGS[@]}" ]; do
    arg="${CLIENT_ARGS[$index]}"
    case "${arg}" in
      -c|--config)
        index=$((index + 1))
        value="${CLIENT_ARGS[$index]:-}"
        case "${value}" in
          "${key}"=*) return 0 ;;
        esac
        ;;
      -c"${key}"=*|--config="${key}"=*)
        return 0
        ;;
    esac
    index=$((index + 1))
  done
  return 1
}

toml_quote() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '"%s"' "${value}"
}

apply_native_prompt_handoff() {
  local prompt_file="${AFS_SESSION_SYSTEM_PROMPT_TEXT:-}"
  if [ "${NATIVE_PROMPT_ENABLED}" = "0" ] || [ -z "${prompt_file}" ] || [ ! -r "${prompt_file}" ]; then
    return 0
  fi

  case "${CLIENT_LABEL}" in
    claude)
      if client_args_has_flag "--system-prompt" || \
         client_args_has_flag "--append-system-prompt" || \
         client_args_has_flag "--system-prompt-file" || \
         client_args_has_flag "--append-system-prompt-file"; then
        return 0
      fi
      CLIENT_EXTRA_ARGS+=(--append-system-prompt-file "${prompt_file}")
      echo "AFS native prompt hook (${CLIENT_LABEL}): --append-system-prompt-file ${prompt_file}" >&2
      ;;
    codex)
      if client_args_has_config_key "instructions" || \
         client_args_has_config_key "developer_instructions" || \
         client_args_has_config_key "model_instructions_file" || \
         client_args_has_config_key "experimental_instructions_file"; then
        return 0
      fi
      CLIENT_EXTRA_ARGS+=(-c "model_instructions_file=$(toml_quote "${prompt_file}")")
      echo "AFS native prompt hook (${CLIENT_LABEL}): model_instructions_file=${prompt_file}" >&2
      ;;
    gemini)
      if [ -n "${GEMINI_SYSTEM_MD:-}" ]; then
        return 0
      fi
      export GEMINI_SYSTEM_MD="${prompt_file}"
      echo "AFS native prompt hook (${CLIENT_LABEL}): GEMINI_SYSTEM_MD=${prompt_file}" >&2
      ;;
  esac
}

start_agent_run_record() {
  if [ "${RECORD_AGENT_RUNS}" = "0" ]; then
    return 0
  fi
  local task_text="${SESSION_TASK:-${SESSION_QUERY:-client session: ${CLIENT_LABEL}}}"
  local start_args=(
    agent-runs start "${task_text}"
    --harness "${CLIENT_LABEL}"
    --workspace "${PWD}"
  )
  if [ -n "${AFS_ACTIVE_CONTEXT_ROOT:-}" ]; then
    start_args+=(--context-root "${AFS_ACTIVE_CONTEXT_ROOT}")
  fi
  if [ -n "${SESSION_PROMPT_FILE:-}" ]; then
    start_args+=(--prompt-file "${SESSION_PROMPT_FILE}")
  elif [ -n "${SESSION_PROMPT_TEXT:-}" ]; then
    start_args+=(--prompt "${SESSION_PROMPT_TEXT}")
  fi
  AFS_AGENT_RUN_ID="$("${AFS_CLI}" "${start_args[@]}" 2>/dev/null || true)"
  AFS_AGENT_RUN_ID="${AFS_AGENT_RUN_ID%%$'\n'*}"
  if [ -n "${AFS_AGENT_RUN_ID}" ]; then
    export AFS_AGENT_RUN_ID
    echo "AFS agent run (${CLIENT_LABEL}): ${AFS_AGENT_RUN_ID}" >&2
  fi
}

seed_agent_jobs() {
  if [ "${SEED_AGENT_JOBS}" = "0" ]; then
    return 0
  fi
  local seed_args=(
    agent-jobs seed
    --path "${PWD}"
    --profile "${SEED_AGENT_JOB_PROFILE}"
    --cadence "${SEED_AGENT_JOB_CADENCE}"
    --created-by "afs-client-session:${CLIENT_LABEL}"
    --quiet
  )
  if [ -n "${AFS_ACTIVE_CONTEXT_ROOT:-}" ]; then
    seed_args+=(--context-root "${AFS_ACTIVE_CONTEXT_ROOT}")
  fi
  "${AFS_CLI}" "${seed_args[@]}" >&2 || true
}

finish_agent_run_record() {
  local run_status="$1"
  local summary="$2"
  if [ -z "${AFS_AGENT_RUN_ID:-}" ]; then
    return 0
  fi
  local command_text
  printf -v command_text '%q ' "${CLIENT_COMMAND}" "${CLIENT_EXTRA_ARGS[@]}" "${CLIENT_ARGS[@]}"
  local finish_args=(
    agent-runs finish "${AFS_AGENT_RUN_ID}"
    --status "${run_status}"
    --summary "${summary}"
  )
  if [ -n "${AFS_ACTIVE_CONTEXT_ROOT:-}" ]; then
    finish_args+=(--context-root "${AFS_ACTIVE_CONTEXT_ROOT}")
  fi
  if [ -n "${command_text}" ]; then
    finish_args+=(--command "${command_text% }")
  fi
  "${AFS_CLI}" "${finish_args[@]}" >&2 || true
}

MONITOR_PID=""
cleanup_monitor() {
  if [ -n "${MONITOR_PID:-}" ]; then
    kill "${MONITOR_PID}" 2>/dev/null || true
    wait "${MONITOR_PID}" 2>/dev/null || true
    MONITOR_PID=""
  fi
}

run_session_hook() {
  local event="$1"
  shift || true
  local hook_args=(
    session hook "${event}"
    --client "${CLIENT_LABEL}"
    --session-id "${AFS_SESSION_ID}"
    --cwd "${PWD}"
  )
  if [ -n "${AFS_SESSION_CLIENT_PAYLOAD_JSON:-}" ]; then
    hook_args+=(--payload-file "${AFS_SESSION_CLIENT_PAYLOAD_JSON}")
  fi
  hook_args+=("$@")
  "${AFS_CLI}" "${hook_args[@]}" >&2
}

run_session_event() {
  local event="$1"
  shift || true
  if [ -x "${AFS_SESSION_EVENT_BIN}" ]; then
    "${AFS_SESSION_EVENT_BIN}" "${event}" "$@" >&2
    return $?
  fi

  local event_args=(
    session event "${event}"
    --client "${CLIENT_LABEL}"
    --session-id "${AFS_SESSION_ID}"
    --cwd "${PWD}"
  )
  if [ -n "${AFS_SESSION_CLIENT_PAYLOAD_JSON:-}" ]; then
    event_args+=(--payload-file "${AFS_SESSION_CLIENT_PAYLOAD_JSON}")
  fi
  if [ -n "${AFS_SESSION_DEFAULT_TURN_ID:-}" ]; then
    case "${event}" in
      session_start|session_end) ;;
      *) event_args+=(--turn-id "${AFS_SESSION_DEFAULT_TURN_ID}") ;;
    esac
  fi
  event_args+=("$@")
  "${AFS_CLI}" "${event_args[@]}" >&2
}

if [ "${MONITOR_AGENTS}" != "0" ] && [ -n "${AFS_SESSION_ID:-}" ]; then
  "${AFS_CLI}" agents monitor --session-id "${AFS_SESSION_ID}" >&2 &
  MONITOR_PID=$!
fi

trap cleanup_monitor EXIT

run_session_hook session_start
seed_agent_jobs

if [ -n "${SESSION_PROMPT}" ] || [ -n "${SESSION_PROMPT_FILE}" ]; then
  prompt_event_args=()
  if [ -n "${AFS_SESSION_DEFAULT_TURN_ID:-}" ]; then
    prompt_event_args+=(--turn-id "${AFS_SESSION_DEFAULT_TURN_ID}")
  fi
  if [ -n "${SESSION_PROMPT_FILE}" ]; then
    prompt_event_args+=(--prompt-file "${SESSION_PROMPT_FILE}")
  else
    prompt_event_args+=(--prompt "${SESSION_PROMPT}")
  fi
  run_session_event user_prompt_submit "${prompt_event_args[@]}"
fi

if [ -n "${AFS_SESSION_DEFAULT_TURN_ID:-}" ]; then
  run_session_event turn_started --turn-id "${AFS_SESSION_DEFAULT_TURN_ID}"
fi

apply_native_prompt_handoff
start_agent_run_record

set +e
"${CLIENT_COMMAND}" "${CLIENT_EXTRA_ARGS[@]}" "${CLIENT_ARGS[@]}"
CLIENT_STATUS=$?
set -e

cleanup_monitor
trap - EXIT

if [ -n "${AFS_SESSION_DEFAULT_TURN_ID:-}" ]; then
  if [ "${CLIENT_STATUS}" -eq 0 ]; then
    run_session_event turn_completed --turn-id "${AFS_SESSION_DEFAULT_TURN_ID}" --exit-code "${CLIENT_STATUS}" --reason client_exit || true
  else
    run_session_event turn_failed --turn-id "${AFS_SESSION_DEFAULT_TURN_ID}" --exit-code "${CLIENT_STATUS}" --reason client_exit || true
  fi
fi

if [ "${WAIT_FOR_AGENTS}" != "0" ] && [ -n "${AFS_SESSION_ID:-}" ]; then
  "${AFS_CLI}" agents wait --all --session-id "${AFS_SESSION_ID}" --timeout "${WAIT_TIMEOUT_SECONDS}" >&2 || true
fi

SESSION_HOOK_STATUS=0
run_session_hook session_end \
  --verification-mode "${SESSION_VERIFICATION_MODE}" \
  --exit-code "${CLIENT_STATUS}" \
  --reason client_exit || SESSION_HOOK_STATUS=$?

AGENT_RUN_FINAL_STATUS="done"
if [ "${CLIENT_STATUS}" -ne 0 ] || { [ "${SESSION_VERIFICATION_MODE}" = "error" ] && [ "${SESSION_HOOK_STATUS}" -ne 0 ]; }; then
  AGENT_RUN_FINAL_STATUS="failed"
fi
finish_agent_run_record "${AGENT_RUN_FINAL_STATUS}" "client_exit status=${CLIENT_STATUS} verification_hook=${SESSION_HOOK_STATUS}"

if [ "${CLIENT_STATUS}" -eq 0 ] && [ "${SESSION_VERIFICATION_MODE}" = "error" ] && [ "${SESSION_HOOK_STATUS}" -ne 0 ]; then
  exit "${SESSION_HOOK_STATUS}"
fi

exit "${CLIENT_STATUS}"
