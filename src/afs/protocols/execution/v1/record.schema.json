{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "afs://schemas/v1/execution/record",
  "title": "AFS Execution Record v1",
  "description": "Bounded process result with redacted arguments and environment fingerprint.",
  "type": "object",
  "required": [
    "schema_version",
    "outcome",
    "caller",
    "purpose",
    "request_sha256",
    "resolved_executable",
    "resolved_cwd",
    "redacted_argv",
    "environment_keys",
    "environment_sha256",
    "timeout_seconds",
    "max_output_bytes",
    "isolation",
    "network",
    "started_at",
    "finished_at",
    "duration_seconds",
    "returncode",
    "timed_out",
    "stdout_truncated",
    "stderr_truncated",
    "reason_codes",
    "reasons",
    "error"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "outcome": {
      "type": "string",
      "enum": ["completed", "failed", "timed_out", "blocked", "spawn_error"]
    },
    "caller": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\uD800-\\uDFFF]*$"
    },
    "purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "pattern": "^[^\\uD800-\\uDFFF]*$"
    },
    "request_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "resolved_executable": {
      "type": "string",
      "maxLength": 32768,
      "pattern": "^[^\\uD800-\\uDFFF]*$"
    },
    "resolved_cwd": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32768,
      "pattern": "^[^\\uD800-\\uDFFF]*$"
    },
    "redacted_argv": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 32768,
        "pattern": "^[^\\uD800-\\uDFFF]*$"
      },
      "maxItems": 256
    },
    "environment_keys": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
      "maxItems": 262,
      "uniqueItems": true
    },
    "environment_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timeout_seconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 3600},
    "max_output_bytes": {"type": "integer", "minimum": 1, "maximum": 10485760},
    "isolation": {"type": "string", "enum": ["process", "sandbox", "container"]},
    "network": {"type": "string", "enum": ["inherit", "deny"]},
    "started_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[^\\uD800-\\uDFFF]*$"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[^\\uD800-\\uDFFF]*$"
    },
    "duration_seconds": {"type": "number", "minimum": 0},
    "returncode": {"type": ["integer", "null"]},
    "timed_out": {"type": "boolean"},
    "stdout": {"type": "string", "pattern": "^[^\\uD800-\\uDFFF]*$"},
    "stderr": {"type": "string", "pattern": "^[^\\uD800-\\uDFFF]*$"},
    "stdout_truncated": {"type": "boolean"},
    "stderr_truncated": {"type": "boolean"},
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[^\\uD800-\\uDFFF]*$"
      },
      "maxItems": 64,
      "uniqueItems": true
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048,
        "pattern": "^[^\\uD800-\\uDFFF]*$"
      },
      "maxItems": 64,
      "uniqueItems": true
    },
    "error": {
      "type": "string",
      "maxLength": 4096,
      "pattern": "^[^\\uD800-\\uDFFF]*$"
    }
  },
  "additionalProperties": false
}
