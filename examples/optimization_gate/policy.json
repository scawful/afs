      "unit": "ms",
      "direction": "minimize",
      "role": "guardrail",
      "max_regression": 20.0,
      "min_samples": 100
    },
    {
      "name": "cost",
      "unit": "usd",
      "direction": "minimize",
      "role": "guardrail",
      "max_regression": 0.005,
      "min_samples": 100
    }
  ],
  "required_constraints": [
    "tests_pass",
    "policy_clean"
  ],
  "confidence_z": 1.0,
