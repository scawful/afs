{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "afs://schemas/v1/optimization/policy",
  "title": "AFS Optimization Policy v1",
  "description": "Deterministic Pareto-style promotion policy for an optimization step.",
  "type": "object",
  "required": [
    "schema_version",
    "algorithm_version",
    "policy_id",
    "metrics",
    "required_constraints",
    "confidence_z",
    "require_same_environment",
    "require_human_approval"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "algorithm_version": {
      "const": "pareto-gate-1.0"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\uD800-\\uDFFF]*$"
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "required": [
          "name",
          "unit",
          "direction",
          "role",
          "max_regression",
          "min_samples"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.-]{0,127}$"
          },
          "unit": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^\\uD800-\\uDFFF]*$"
          },
          "direction": {
            "type": "string",
            "enum": ["maximize", "minimize"]
          },
          "role": {
            "type": "string",
            "enum": ["objective", "guardrail"]
          },
          "min_delta": {
            "type": "number"
          },
          "max_regression": {
            "type": "number",
            "minimum": 0
          },
          "min_samples": {
            "type": "integer",
            "minimum": 1
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "role": {
                  "const": "objective"
                }
              },
              "required": ["role"]
            },
            "then": {
              "required": ["min_delta"],
              "properties": {
                "min_delta": {
                  "exclusiveMinimum": 0
                }
              }
            },
            "else": {
              "not": {
                "required": ["min_delta"]
              }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "required_constraints": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[^\\uD800-\\uDFFF]*$"
      },
      "uniqueItems": true
    },
    "confidence_z": {
      "type": "number",
      "minimum": 0
    },
    "require_same_environment": {
      "type": "boolean"
    },
    "require_human_approval": {
      "const": true
    }
  },
  "additionalProperties": false
}
