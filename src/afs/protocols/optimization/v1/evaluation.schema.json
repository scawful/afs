{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "afs://schemas/v1/optimization/evaluation",
  "title": "AFS Optimization Evaluation v1",
  "description": "Versioned evidence record for one immutable optimization candidate.",
  "type": "object",
  "required": [
    "schema_version",
    "candidate_id",
    "parent_id",
    "artifact_sha256",
    "evaluation_suite",
    "provenance",
    "metrics",
    "constraints"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\uD800-\\uDFFF]*$"
    },
    "parent_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\uD800-\\uDFFF]*$"
    },
    "artifact_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifact_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\uD800-\\uDFFF]*$"
    },
    "evaluation_suite": {
      "type": "object",
      "required": ["name", "version", "case_set_sha256"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\uD800-\\uDFFF]*$"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\uD800-\\uDFFF]*$"
        },
        "case_set_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "run_id",
        "evaluator",
        "evaluator_version",
        "seed",
        "environment_sha256"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\uD800-\\uDFFF]*$"
        },
        "evaluator": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\uD800-\\uDFFF]*$"
        },
        "evaluator_version": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\uD800-\\uDFFF]*$"
        },
        "seed": {
          "type": "integer"
        },
        "environment_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "source_revision": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\uD800-\\uDFFF]*$"
        }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "required": ["name", "unit", "value", "sample_count"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.-]{0,127}$"
          },
          "unit": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^\\uD800-\\uDFFF]*$"
          },
          "value": {
            "type": "number"
          },
          "sample_count": {
            "type": "integer",
            "minimum": 1
          },
          "standard_error": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "constraints": {
      "type": "object",
      "maxProperties": 256,
      "propertyNames": {
        "pattern": "^[^\\uD800-\\uDFFF]*$"
      },
      "additionalProperties": {
        "type": "boolean"
      }
    }
  },
  "additionalProperties": false
}
